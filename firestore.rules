rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ──────────────────────────────────────────────
    // Raiz dos artefatos: artifacts/{appId}/...
    // ──────────────────────────────────────────────
    match /artifacts/{appId} {

      // Perfil privado do usuário — somente o próprio dono pode ler/escrever
      match /users/{userId}/profile/data {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Índice público de e-mails para busca de convites
      // Leitura: qualquer autenticado | Escrita: somente o próprio usuário
      match /public/data/emails/{email} {
        allow read: if request.auth != null;
        allow write: if request.auth != null
          && request.resource.data.uid == request.auth.uid;
      }

      // Viagens (trips) — leitura aberta a autenticados; criação pelo dono
      match /public/data/trips/{tripId} {
        allow read: if request.auth != null;

        // Criação: o autor deve incluir a si mesmo como membro
        allow create: if request.auth != null
          && request.resource.data.creator == request.auth.uid
          && request.auth.uid in request.resource.data.members;

        // Atualização: membros da viagem podem alterar livremente;
        // um não-membro só pode se auto-adicionar (aceitar convite),
        // alterando exclusivamente o campo members e somando 1 participante
        allow update: if request.auth != null
          && (
            request.auth.uid in resource.data.members
            || (
              request.auth.uid in request.resource.data.members
              && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members'])
              && request.resource.data.members.size() == resource.data.members.size() + 1
            )
          );
      }

      // Convites — leitura aberta a autenticados
      match /public/data/invites/{inviteId} {
        allow read: if request.auth != null;

        // Apenas o remetente pode criar o convite
        allow create: if request.auth != null
          && request.resource.data.fromUid == request.auth.uid;

        // O destinatário pode atualizar o status (aceitar/recusar)
        allow update: if request.auth != null
          && resource.data.toUid == request.auth.uid;
      }

      // Despesas por viagem — leitura/criação por membros autenticados
      match /public/data/{expenseCol}/{expenseId} {
        allow read: if request.auth != null
          && expenseCol.matches('expenses_.*');

        allow create: if request.auth != null
          && expenseCol.matches('expenses_.*')
          && request.resource.data.uid == request.auth.uid;
      }

      // Dicas e cronograma por viagem
      match /public/data/{tipsCol}/{tipId} {
        allow read: if request.auth != null
          && tipsCol.matches('tips_.*');

        // Qualquer autenticado pode criar uma dica
        allow create: if request.auth != null
          && tipsCol.matches('tips_.*')
          && request.resource.data.createdBy == request.auth.uid;

        // Qualquer autenticado pode votar (atualizar votesUp/votesDown/status)
        allow update: if request.auth != null
          && tipsCol.matches('tips_.*');
      }
    }
  }
}
