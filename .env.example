# Copie este arquivo para .env.local e preencha com seus dados do Firebase Console
# Nunca comite o arquivo .env.local no git

VITE_FIREBASE_API_KEY=AIzaSy...
VITE_FIREBASE_AUTH_DOMAIN=seu-projeto.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=seu-projeto
VITE_FIREBASE_STORAGE_BUCKET=seu-projeto.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abc123

# Identificador interno das coleções Firestore (pode ser qualquer string única)
VITE_APP_ID=gotravel-app
